<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="#F1F5F9"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_btn_prev"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/widget_arrow_prev"
            android:textColor="#475569"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_month_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text=""
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_next"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/widget_arrow_next"
            android:textColor="#475569"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_calendar_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="#FFFFFFFF"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_sun"
                android:textColor="#FB7185"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_mon"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_tue"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_wed"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_thu"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_fri"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/widget_weekday_sat"
                android:textColor="#3B82F6"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <GridView
            android:id="@+id/widget_calendar_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFFFF"
            android:columnWidth="44dp"
            android:gravity="top"
            android:horizontalSpacing="0dp"
            android:numColumns="7"
            android:stretchMode="columnWidth"
            android:verticalSpacing="0dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/widget_calendar_empty"
        android:textColor="#94A3B8"
        android:textSize="10sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_today_notes_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="#FFFFFFFF"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/widget_today_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_today_schedule_title"
            android:textColor="#1E293B"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Card 1 -->
        <LinearLayout
            android:id="@+id/widget_note_card_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/widget_note_card_bg"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/widget_note_card_1_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3730A3"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_note_card_1_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 2 -->
        <LinearLayout
            android:id="@+id/widget_note_card_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/widget_note_card_bg"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/widget_note_card_2_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3730A3"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_note_card_2_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 3 -->
        <LinearLayout
            android:id="@+id/widget_note_card_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/widget_note_card_bg"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/widget_note_card_3_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3730A3"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_note_card_3_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 4 -->
        <LinearLayout
            android:id="@+id/widget_note_card_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/widget_note_card_bg"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/widget_note_card_4_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3730A3"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_note_card_4_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 5 -->
        <LinearLayout
            android:id="@+id/widget_note_card_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/widget_note_card_bg"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="8dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/widget_note_card_5_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3730A3"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_note_card_5_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_today_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/widget_today_schedule_empty"
            android:textColor="#94A3B8"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
